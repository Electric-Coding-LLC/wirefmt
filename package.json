{
  "name": "wirefmt",
  "version": "0.0.0",
  "description": "Formats and cleans up ASCII wireframes generated by humans or AI agents.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "wirefmt": "./src/cli/bin.ts",
    "wirefmt-mcp": "./src/mcp/bin.ts"
  },
  "scripts": {
    "check": "bun run typecheck && bun run lint && bun test",
    "format": "biome format --write .",
    "lint": "biome check .",
    "mcp": "bun run src/mcp/bin.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.3.11"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "^1.3.12",
    "typescript": "^6.0.3"
  }
}
